{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/deepseek-v4-flash",
  "instructions": [
    "AGENTS.md"
  ],
  "permission": {
    "bash": {
      "*": "ask",
      "python *": "allow",
      "pip *": "allow",
      "ruff *": "allow",
      "flake8 *": "allow",
      "git *": "allow",
      "mkdir *": "allow",
      "ls": "allow",
      "cp *": "allow",
      "mv *": "allow",
      "rm *": "allow",
      "trash *": "allow",
      "rm -rf /": "deny",
      "sudo *": "deny",
      "chmod *": "deny",
      "chown *": "deny"
    },
    "edit": {
      "*": "deny",
      "agentspec/**/*.py": "allow",
      "tests/**/*.py": "allow",
      "examples/**/*.yaml": "allow",
      "docs/**/*.md": "allow",
      "AGENTS.md": "allow",
      "pyproject.toml": "allow",
      ".mcp.json": "allow",
      ".opencode/skills/**/*.md": "allow",
      ".flake8": "allow"
    },
    "read": "allow",
    "webfetch": "allow",
    "question": "allow",
    "todowrite": "allow"
  },
  "command": {
    "test": {
      "description": "Run all tests",
      "template": "python -m pytest tests/ -v --tb=short"
    },
    "lint": {
      "description": "Run ruff + flake8 linters",
      "template": "ruff check . && flake8 agentspec/ tests/"
    },
    "flake8": {
      "description": "Run flake8 linter",
      "template": "flake8 agentspec/ tests/"
    },
    "coverage": {
      "description": "Run tests with coverage",
      "template": "python -m pytest tests/ --cov=agentspec"
    },
    "validate": {
      "description": "Validate a spec file",
      "template": "agentspec validate {{spec_file}}"
    }
  },
  "skills": {
    "paths": [
      ".opencode/skills"
    ]
  },
  "mcp": {
    "spec-manager": {
      "type": "local",
      "command": [
        "python",
        "-m",
        "agentspec.mcp.spec_manager"
      ]
    },
    "eval-runner": {
      "type": "local",
      "command": [
        "python",
        "-m",
        "agentspec.mcp.eval_runner"
      ]
    },
    "results-store": {
      "type": "local",
      "command": [
        "python",
        "-m",
        "agentspec.mcp.results_store"
      ]
    },
    "mock-agent": {
      "type": "local",
      "command": [
        "python",
        "-m",
        "agentspec.mcp.mock_agent"
      ]
    },
    "spec-templates": {
      "type": "local",
      "command": [
        "python",
        "-m",
        "agentspec.mcp.spec_templates"
      ]
    },
    "tests-runner": {
      "type": "local",
      "command": [
        "python",
        "-m",
        "agentspec.mcp.tests_runner"
      ]
    }
  }
}

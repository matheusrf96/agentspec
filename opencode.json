{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/deepseek-v4-flash",
  "instructions": [
    "AGENTS.md"
  ],
  "permission": {
    "bash": {
      "*": "ask",
      "python *": "allow",
      "pip *": "allow",
      "ruff *": "allow",
      "flake8 *": "allow",
      "pyright *": "allow",
      "mkdir *": "allow",
      "ls": "allow",
      "cp *": "allow",
      "mv *": "allow"
    },
    "edit": "allow",
    "read": "allow",
    "webfetch": "allow",
    "question": "allow",
    "todowrite": "allow"
  },
  "command": {
    "test": {
      "description": "Run all tests",
      "template": "python -m pytest tests/ -v --tb=short --cov=agentspec --cov-fail-under=95"
    },
    "lint": {
      "description": "Run ruff check + ruff format check + flake8 + pyright",
      "template": "ruff check . && ruff format --check . && flake8 agentspec/ tests/ && pyright agentspec/ tests/"
    },
    "flake8": {
      "description": "Run flake8 linter",
      "template": "flake8 agentspec/ tests/"
    },
    "coverage": {
      "description": "Run tests with coverage",
      "template": "python -m pytest tests/ --cov=agentspec --cov-fail-under=95"
    },
    "validate": {
      "description": "Validate a spec file",
      "template": "agentspec validate {{spec_file}}"
    },
    "typecheck": {
      "description": "Run pyright type checker",
      "template": "pyright agentspec/ tests/"
    },
    "format": {
      "description": "Auto-format code with ruff",
      "template": "ruff format agentspec/ tests/"
    }
  },
  "skills": {
    "paths": [
      ".opencode/skills"
    ]
  },
  "mcp": {
    "spec-manager": {
      "type": "local",
      "command": [
        "python",
        "-m",
        "agentspec.mcp.spec_manager"
      ]
    },
    "eval-runner": {
      "type": "local",
      "command": [
        "python",
        "-m",
        "agentspec.mcp.eval_runner"
      ]
    },
    "results-store": {
      "type": "local",
      "command": [
        "python",
        "-m",
        "agentspec.mcp.results_store"
      ]
    },
    "mock-agent": {
      "type": "local",
      "command": [
        "python",
        "-m",
        "agentspec.mcp.mock_agent"
      ]
    },
    "spec-templates": {
      "type": "local",
      "command": [
        "python",
        "-m",
        "agentspec.mcp.spec_templates"
      ]
    },
    "tests-runner": {
      "type": "local",
      "command": [
        "python",
        "-m",
        "agentspec.mcp.tests_runner"
      ]
    }
  }
}